{
  "name": "retrograde",
  "version": "1.6.0",
  "description": "Curadoria inteligente de coleções de jogos baseada em avaliações da IGDB e TheGamesDB",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "electron:dev": "tsc -p electron/tsconfig.json && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && set VITE_DEV_SERVER_URL=http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && electron-builder"
  },
  "keywords": [
    "retro",
    "gaming",
    "roms"
  ],
  "author": "from80s",
  "license": "MIT",
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "pngquant-bin": "^9.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "7zip-min": "^3.0.1",
    "adm-zip": "^0.5.17",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.10.0",
    "crc-32": "^1.2.2",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^11.13.0",
    "fs-extra": "^11.2.0",
    "lucide-react": "^0.468.0",
    "node-gzip": "^1.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tar": "^7.5.15",
    "unzipper": "^0.12.3"
  },
  "build": {
    "appId": "com.retrograde.app",
    "productName": "RetroGrade",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "data/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/rom_database_optimized.sqlite",
        "to": "assets/rom_database_optimized.sqlite"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/images/RetroGrade_icon_app_256x256.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RetroGrade"
    }
  }
}
